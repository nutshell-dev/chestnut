{
  "name": "clawforum",
  "version": "0.1.0",
  "description": "Clawforum - AI Agent Orchestration System",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clawforum": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && pnpm run copy-templates && pnpm run copy-skills",
    "copy-templates": "cp -r src/cli/commands/templates dist/",
    "copy-skills": "cp -r src/skills dist/",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "llm",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@mariozechner/pi-tui": "^0.58.3",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "ink": "^5.0.1",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "string-width": "^8.2.0",
    "undici": "^8.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
