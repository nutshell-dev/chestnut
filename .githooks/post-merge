#!/usr/bin/env bash
# Post-merge hook: verify merged tree compiles and tests pass.
# Enabled via: git config core.hooksPath .githooks
# If this fails, the merge has already completed; consider manual rollback.

set -euo pipefail

LOCKFILE="/tmp/chestnut-post-merge.lock"
LOCK_TIMEOUT=600  # 10 min max wait for previous run
TEST_TIMEOUT=600  # 10 min max for test suite

# ── mutex: only one post-merge test at a time ──
exec 9>"$LOCKFILE"
if ! flock -w "$LOCK_TIMEOUT" 9; then
  echo "[post-merge] SKIP: could not acquire lock (another post-merge test running)"
  exit 0
fi

cleanup() {
  # Kill any leftover vitest/node child processes from this run
  pkill -P $$ 2>/dev/null || true
  flock -u 9 2>/dev/null || true
}
trap cleanup EXIT

echo "[post-merge] running pnpm typecheck..."
if ! pnpm run typecheck; then
  echo ""
  echo "[post-merge] TYPECHECK FAILED on merged tree."
  echo "[post-merge] The merge is already recorded. Options:"
  echo "[post-merge]   1. git reset --hard HEAD~1   (if HEAD~1 is correct)"
  echo "[post-merge]   2. investigate and fix forward"
  exit 1
fi

echo "[post-merge] running pnpm test:diff..."
if ! timeout "$TEST_TIMEOUT" pnpm run test:diff; then
  echo ""
  echo "[post-merge] TESTS FAILED (or timed out) on merged tree."
  exit 1
fi

echo "[post-merge] green."
